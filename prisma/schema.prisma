generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Zone {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  label    String
  sections Section[]

  @@map("tableZone")
}

model Section {
  id        Int        @id @default(autoincrement())
  name      String
  zoneId    Int
  attendees Attendee[]
  zone      Zone       @relation(fields: [zoneId], references: [id])

  @@map("tableSection")
}

model Attendee {
  memberName    String
  job           String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  uid           String          @id
  attendance    String?
  attendanceAt  DateTime?
  sectionId     Int?
  position      Int?
  tags          String[]
  prevSectionId Int?
  skills        AttendeeSkill[]
  section       Section?        @relation(fields: [sectionId], references: [id])

  @@index([memberName])
  @@map("tableMemberName")
}

model Skill {
  id        Int             @id @default(autoincrement())
  imagePath String
  attendees AttendeeSkill[]

  @@map("tableSkill")
}

model AttendeeSkill {
  attendeeUid String
  skillId     Int
  attendee    Attendee @relation(fields: [attendeeUid], references: [uid])
  skill       Skill    @relation(fields: [skillId], references: [id])

  @@id([attendeeUid, skillId])
  @@map("tableAttendeeSkill")
}
